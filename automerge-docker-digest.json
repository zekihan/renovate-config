{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"packageRules": [
		{
			"matchDatasources": [
				"docker"
			],
			"automerge": true,
      "automergeType": "branch",
			"groupName": "container-digest-updates",
			"matchUpdateTypes": [
				"digest"
			],
			"ignoreTests": true
		}
	]
}
