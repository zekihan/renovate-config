{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"packageRules": [
		{
			"matchManagers": [
				"github-actions"
			],
			"automerge": true,
      "automergeType": "branch",
			"groupName": "github-actions-updates",
			"matchUpdateTypes": [
				"minor",
				"patch",
				"digest"
			],
			"ignoreTests": true
		}
	]
}
